#!/usr/bin/env python3
# origin: maestro
# maestro_version: v2026.07.16.2
"""mem — CLI wrapper su memories.db.

Riduce verbosity, escape, error-rate delle scritture SQL grezze da parte
dell'orchestrator. Output table su TTY, JSON su pipe.
Path db: env MEM_DB > <repo>/private/memories.db (auto-detect dal path dello script).
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sqlite3
import sys
from contextlib import contextmanager
from datetime import datetime, timedelta, date
from pathlib import Path
from typing import Any, Iterable

# ---------------------------------------------------------------------------
# DB path resolution
# ---------------------------------------------------------------------------

def _repo_root() -> Path:
    return Path(__file__).resolve().parent.parent


def db_path() -> Path:
    env = os.environ.get("MEM_DB")
    if env:
        return Path(env).expanduser()
    return _repo_root() / "private" / "memories.db"


@contextmanager
def connect():
    p = db_path()
    if not p.exists():
        sys.stderr.write(f"mem: db not found at {p}\n")
        sys.exit(2)
    con = sqlite3.connect(str(p))
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA foreign_keys = ON")
    try:
        yield con
        con.commit()
    finally:
        con.close()


# ---------------------------------------------------------------------------
# Date parsing
# ---------------------------------------------------------------------------

_REL_RE = re.compile(r"^([+-])(\d+)([dwm])$")


def parse_date(s: str | None, *, allow_keywords: bool = True) -> str | None:
    """Parse a date spec into 'YYYY-MM-DD'. None passes through."""
    if s is None:
        return None
    s = s.strip()
    if not s:
        return None
    today = date.today()
    if allow_keywords:
        kw = s.lower()
        if kw == "today":
            return today.isoformat()
        if kw == "yesterday":
            return (today - timedelta(days=1)).isoformat()
        if kw == "tomorrow":
            return (today + timedelta(days=1)).isoformat()
    m = _REL_RE.match(s)
    if m:
        sign, n, unit = m.group(1), int(m.group(2)), m.group(3)
        delta_days = {"d": n, "w": n * 7, "m": n * 30}[unit]
        delta = timedelta(days=delta_days if sign == "+" else -delta_days)
        return (today + delta).isoformat()
    # ISO date
    try:
        return datetime.strptime(s, "%Y-%m-%d").date().isoformat()
    except ValueError as e:
        raise SystemExit(f"mem: invalid date '{s}' ({e})")


def effective_today() -> str:
    """Today, with early-morning rule (00:00–06:00 → ieri)."""
    now = datetime.now()
    if now.hour < 6:
        return (now.date() - timedelta(days=1)).isoformat()
    return now.date().isoformat()


# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

def is_tty() -> bool:
    return sys.stdout.isatty()


def emit_json(payload: Any) -> None:
    json.dump(payload, sys.stdout, ensure_ascii=False, separators=(",", ":"))
    sys.stdout.write("\n")


def emit_table(rows: list[dict], cols: list[str]) -> None:
    if not rows:
        print("(empty)")
        return
    widths = {c: max(len(c), *(len(str(r.get(c) or "")) for r in rows)) for c in cols}
    header = " | ".join(c.ljust(widths[c]) for c in cols)
    sep = "-+-".join("-" * widths[c] for c in cols)
    print(header)
    print(sep)
    for r in rows:
        print(" | ".join(str(r.get(c) or "").ljust(widths[c]) for c in cols))


def emit_rows(rows: list[dict], cols: list[str], force_json: bool) -> None:
    if force_json or not is_tty():
        emit_json(rows)
    else:
        emit_table(rows, cols)


def announce(line: str, *, json_mode: bool) -> None:
    """Announcement on stdout (or skipped in --json mode if writing JSON payload)."""
    if json_mode:
        return
    print(line)


def tags_list(tags: str | None) -> list[str]:
    if not tags:
        return []
    return [t.strip() for t in tags.split(",") if t.strip()]


# ---------------------------------------------------------------------------
# Write commands
# ---------------------------------------------------------------------------

def _insert_log(con: sqlite3.Connection, row: dict) -> int:
    cols = [
        "date", "title", "description", "tags",
        "type", "status", "due_date", "completed_date", "priority",
    ]
    values = [row.get(c) for c in cols]
    cur = con.execute(
        f"INSERT INTO log ({','.join(cols)}) VALUES ({','.join('?' * len(cols))})",
        values,
    )
    return cur.lastrowid


def cmd_save(args) -> int:
    if args.bulk:
        return _bulk_save(args)
    row = {
        "date": parse_date(args.date) or effective_today(),
        "title": args.title,
        "description": args.description,
        "tags": ",".join(args.tags) if args.tags else None,
        "type": "memory",
    }
    with connect() as con:
        rid = _insert_log(con, row)
    payload = {"id": rid, **row}
    if args.json:
        emit_json(payload)
    else:
        tags = row["tags"] or ""
        announce(f'📝 saved: "{row["title"]}" [{tags}] (memory) #{rid}', json_mode=False)
    return 0


def _bulk_save(args) -> int:
    """Read JSON array from stdin, insert all in single transaction."""
    raw = sys.stdin.read()
    try:
        items = json.loads(raw)
    except json.JSONDecodeError as e:
        sys.stderr.write(f"mem: invalid JSON on stdin: {e}\n")
        return 2
    if not isinstance(items, list):
        sys.stderr.write("mem: --bulk expects JSON array\n")
        return 2
    inserted = []
    today = effective_today()
    with connect() as con:
        for item in items:
            row = {
                "date": parse_date(item.get("date")) or today,
                "title": item.get("title") or "(untitled)",
                "description": item.get("description"),
                "tags": item.get("tags"),
                "type": item.get("type") or "memory",
                "status": item.get("status"),
                "due_date": parse_date(item.get("due_date")),
                "completed_date": parse_date(item.get("completed_date")),
                "priority": item.get("priority") or "normal",
            }
            # memory has NULL status
            if row["type"] == "memory":
                row["status"] = None
            rid = _insert_log(con, row)
            inserted.append({"id": rid, "title": row["title"], "type": row["type"]})
    if args.json or not is_tty():
        emit_json({"inserted": inserted, "count": len(inserted)})
    else:
        print(f"📦 bulk: inserted {len(inserted)} row(s)")
        for r in inserted:
            print(f"  #{r['id']} [{r['type']}] {r['title']}")
    return 0


def cmd_task(args) -> int:
    row = {
        "date": parse_date(args.date) or effective_today(),
        "title": args.title,
        "description": args.description,
        "tags": ",".join(args.tags) if args.tags else None,
        "type": "task",
        "status": "todo",
        "due_date": parse_date(args.due),
        "priority": args.priority or "normal",
    }
    with connect() as con:
        rid = _insert_log(con, row)
    if args.json:
        emit_json({"id": rid, **row})
    else:
        tags = row["tags"] or ""
        due = f" due:{row['due_date']}" if row["due_date"] else ""
        announce(
            f'📝 task: "{row["title"]}" [{tags}]{due} (priority:{row["priority"]}) #{rid}',
            json_mode=False,
        )
    return 0


def cmd_idea(args) -> int:
    row = {
        "date": parse_date(args.date) or effective_today(),
        "title": args.title,
        "description": args.description,
        "tags": ",".join(args.tags) if args.tags else None,
        "type": "idea",
        "status": "open",
    }
    with connect() as con:
        rid = _insert_log(con, row)
    if args.json:
        emit_json({"id": rid, **row})
    else:
        tags = row["tags"] or ""
        announce(f'💡 idea: "{row["title"]}" [{tags}] (open) #{rid}', json_mode=False)
    return 0


def cmd_update(args) -> int:
    fields = {}
    if args.title is not None: fields["title"] = args.title
    if args.description is not None: fields["description"] = args.description
    if args.tags is not None: fields["tags"] = ",".join(args.tags)
    if args.status is not None: fields["status"] = args.status
    if args.due is not None: fields["due_date"] = parse_date(args.due)
    if args.priority is not None: fields["priority"] = args.priority
    if args.date is not None: fields["date"] = parse_date(args.date)
    if not fields:
        sys.stderr.write("mem: nothing to update\n")
        return 1
    set_clause = ", ".join(f"{k}=?" for k in fields)
    with connect() as con:
        cur = con.execute(
            f"UPDATE log SET {set_clause} WHERE id=?",
            (*fields.values(), args.id),
        )
        if cur.rowcount == 0:
            sys.stderr.write(f"mem: no row with id {args.id}\n")
            return 1
    changed = ", ".join(f"{k}={v!r}" for k, v in fields.items())
    if args.json:
        emit_json({"id": args.id, "updated": fields})
    else:
        announce(f"✏️ updated #{args.id}: {changed}", json_mode=False)
    return 0


def cmd_done(args) -> int:
    today = effective_today()
    with connect() as con:
        for rid in args.ids:
            cur = con.execute(
                "UPDATE log SET status='done', completed_date=? WHERE id=? AND type='task'",
                (today, rid),
            )
            if cur.rowcount == 0:
                sys.stderr.write(f"mem: no task with id {rid}\n")
                return 1
    if args.json:
        emit_json({"done": args.ids, "completed_date": today})
    else:
        for rid in args.ids:
            announce(f"✅ done #{rid}", json_mode=False)
    return 0


def cmd_reopen(args) -> int:
    with connect() as con:
        cur = con.execute(
            "UPDATE log SET status='todo', completed_date=NULL WHERE id=? AND type='task'",
            (args.id,),
        )
        if cur.rowcount == 0:
            sys.stderr.write(f"mem: no task with id {args.id}\n")
            return 1
    if args.json:
        emit_json({"reopened": args.id})
    else:
        announce(f"↩️ reopened #{args.id}", json_mode=False)
    return 0


# ---------------------------------------------------------------------------
# Marker commands (kv-style on log table, retrocompat with last-slacky-flush)
# ---------------------------------------------------------------------------

def cmd_marker(args) -> int:
    if args.action == "get":
        with connect() as con:
            row = con.execute(
                "SELECT id, date, description FROM log WHERE title=? AND type='memory' "
                "AND tags LIKE '%marker%' ORDER BY id DESC LIMIT 1",
                (args.name,),
            ).fetchone()
            # fallback: any record with title=<name> (retrocompat con marker pre-CLI)
            if row is None:
                row = con.execute(
                    "SELECT id, date, description FROM log WHERE title=? "
                    "ORDER BY id DESC LIMIT 1",
                    (args.name,),
                ).fetchone()
        if row is None:
            if args.json:
                emit_json({"name": args.name, "value": None})
            return 0
        if args.json:
            emit_json({"name": args.name, "value": row["description"], "id": row["id"], "date": row["date"]})
        else:
            print(row["description"] or "")
        return 0

    if args.action == "set":
        today = effective_today()
        with connect() as con:
            existing = con.execute(
                "SELECT id FROM log WHERE title=? ORDER BY id DESC LIMIT 1",
                (args.name,),
            ).fetchone()
            if existing:
                con.execute(
                    "UPDATE log SET date=?, description=?, tags=? WHERE id=?",
                    (today, args.value, "marker", existing["id"]),
                )
                rid = existing["id"]
                action = "updated"
            else:
                cur = con.execute(
                    "INSERT INTO log (date, title, description, tags, type) "
                    "VALUES (?, ?, ?, 'marker', 'memory')",
                    (today, args.name, args.value),
                )
                rid = cur.lastrowid
                action = "created"
        if args.json:
            emit_json({"name": args.name, "value": args.value, "id": rid, "action": action})
        else:
            announce(f"🏷️ marker {action} #{rid}: {args.name} = {args.value}", json_mode=False)
        return 0

    sys.stderr.write("mem marker: unknown action\n")
    return 2


# ---------------------------------------------------------------------------
# Read commands
# ---------------------------------------------------------------------------

_DEFAULT_COLS = ["id", "date", "type", "status", "title", "tags"]


def _row_to_dict(row: sqlite3.Row) -> dict:
    return {k: row[k] for k in row.keys()}


def _query(con: sqlite3.Connection, where: str, params: Iterable, order: str = "date DESC, id DESC", limit: int | None = None) -> list[dict]:
    sql = f"SELECT * FROM log WHERE {where} ORDER BY {order}"
    if limit:
        sql += f" LIMIT {int(limit)}"
    return [_row_to_dict(r) for r in con.execute(sql, list(params)).fetchall()]


def cmd_today(args) -> int:
    with connect() as con:
        rows = _query(con, "date=?", [effective_today()], order="id ASC")
    emit_rows(rows, _DEFAULT_COLS, args.json)
    return 0


def cmd_todo(args) -> int:
    with connect() as con:
        rows = _query(
            con,
            "type='task' AND status IN ('todo','in_progress')",
            [],
            order=(
                "CASE priority WHEN 'high' THEN 1 WHEN 'normal' THEN 2 WHEN 'low' THEN 3 END, "
                "due_date NULLS LAST, id"
            ),
        )
    cols = ["id", "title", "status", "priority", "due_date", "tags"]
    emit_rows(rows, cols, args.json)
    return 0


def cmd_overdue(args) -> int:
    today = effective_today()
    with connect() as con:
        rows = _query(
            con,
            "type='task' AND status IN ('todo','in_progress') AND due_date < ?",
            [today],
            order="due_date ASC, id",
        )
    cols = ["id", "title", "due_date", "priority", "tags"]
    emit_rows(rows, cols, args.json)
    return 0


def cmd_search(args) -> int:
    if args.semantic:
        return _cmd_search_semantic(args)
    clauses = []
    params: list[Any] = []
    if args.query:
        like = f"%{args.query}%"
        clauses.append("(title LIKE ? OR description LIKE ? OR tags LIKE ?)")
        params.extend([like, like, like])
    if args.tag:
        for t in args.tag:
            clauses.append("tags LIKE ?")
            params.append(f"%{t}%")
    if args.type:
        clauses.append("type=?")
        params.append(args.type)
    if args.status:
        clauses.append("status=?")
        params.append(args.status)
    if args.since:
        clauses.append("date>=?")
        params.append(parse_date(args.since))
    if args.until:
        clauses.append("date<=?")
        params.append(parse_date(args.until))
    where = " AND ".join(clauses) if clauses else "1=1"
    with connect() as con:
        rows = _query(con, where, params, limit=args.limit)
    emit_rows(rows, _DEFAULT_COLS, args.json)
    return 0


def cmd_show(args) -> int:
    with connect() as con:
        row = con.execute("SELECT * FROM log WHERE id=?", (args.id,)).fetchone()
    if row is None:
        sys.stderr.write(f"mem: no row with id {args.id}\n")
        return 1
    d = _row_to_dict(row)
    if args.json or not is_tty():
        emit_json(d)
    else:
        for k, v in d.items():
            if v is None or v == "":
                continue
            print(f"{k:>16}: {v}")
    return 0


def cmd_stats(args) -> int:
    with connect() as con:
        total = con.execute("SELECT COUNT(*) FROM log").fetchone()[0]
        by_type = {
            r["type"]: r["n"]
            for r in con.execute("SELECT type, COUNT(*) AS n FROM log GROUP BY type")
        }
        open_tasks = con.execute(
            "SELECT COUNT(*) FROM log WHERE type='task' AND status IN ('todo','in_progress')"
        ).fetchone()[0]
        open_ideas = con.execute(
            "SELECT COUNT(*) FROM log WHERE type='idea' AND status='open'"
        ).fetchone()[0]
        first = con.execute("SELECT MIN(date) FROM log").fetchone()[0]
        last = con.execute("SELECT MAX(date) FROM log").fetchone()[0]
    payload = {
        "total": total,
        "by_type": by_type,
        "open_tasks": open_tasks,
        "open_ideas": open_ideas,
        "first_date": first,
        "last_date": last,
    }
    if args.json or not is_tty():
        emit_json(payload)
    else:
        print(f"total rows: {total}")
        print(f"  by type:  {by_type}")
        print(f"  open tasks: {open_tasks}")
        print(f"  open ideas: {open_ideas}")
        print(f"  date range: {first} → {last}")
    return 0


# ---------------------------------------------------------------------------
# Semantic layer (delega a bin/mem-vec via uv; degrada con grazia, exit 3)
# ---------------------------------------------------------------------------

EXIT_SEM_UNAVAILABLE = 3

_SEM_COLS = ["source", "ref", "title", "score", "snippet"]


def _vec_run(vec_args: list[str]) -> tuple[int, str]:
    import shutil
    import subprocess
    uv = shutil.which("uv")
    if uv is None:
        sys.stderr.write(
            "mem: strato semantico non disponibile — 'uv' non installato "
            "(brew install uv). La ricerca keyword resta attiva.\n")
        return EXIT_SEM_UNAVAILABLE, ""
    script = Path(__file__).resolve().parent / "mem-vec"
    env = os.environ.copy()
    env.setdefault("MEM_DB", str(db_path()))
    proc = subprocess.run(
        [uv, "run", "--script", str(script), *vec_args],
        capture_output=True, text=True, env=env)
    if proc.returncode != 0:
        sys.stderr.write(proc.stderr)
        return proc.returncode, ""
    return 0, proc.stdout


def cmd_embed(args) -> int:
    vec_args = ["embed"]
    if args.rebuild:
        vec_args.append("--rebuild")
    if args.status:
        vec_args.append("--status")
    if args.model:
        vec_args += ["--model", args.model]
    for r in (getattr(args, "root", None) or []):
        vec_args += ["--root", r]
    rc, out = _vec_run(vec_args)
    if rc != 0:
        return rc
    payload = json.loads(out)
    if args.json or not is_tty():
        emit_json(payload)
    elif args.status:
        m = payload["memory"]
        print(f"🧭 embedding: {m['embedded']}/{m['total']} ok, "
              f"{m['stale']} stale, {m['missing']} mancanti "
              f"(model {payload['model']})")
        if isinstance(payload.get("vault"), dict):
            v = payload["vault"]
            print(f"   📚 vault: {v['embedded']}/{v['total']} ok, "
                  f"{v['stale']} stale, {v['missing']} mancanti, "
                  f"{v['orphans']} orfani")
    else:
        print(f"🧠 embedded {payload['embedded']} row(s) in {payload['seconds']}s "
              f"(model {payload['model']})")
    if not args.status and isinstance(payload.get("vault"), dict) and is_tty() and not args.json:
        v = payload["vault"]
        print(f"   📚 vault: +{v['embedded']} chunk, -{v['orphans_removed']} orfani")
    return 0


def _cmd_search_semantic(args) -> int:
    if not args.query:
        sys.stderr.write("mem: --semantic richiede una query di testo\n")
        return 2
    vec_args = ["search", args.query, "--limit", str(args.limit),
                "--min-score", str(args.min_score)]
    if args.type:
        vec_args += ["--type", args.type]
    if args.status:
        vec_args += ["--status", args.status]
    if args.since:
        vec_args += ["--since", parse_date(args.since)]
    if args.until:
        vec_args += ["--until", parse_date(args.until)]
    for t in (args.tag or []):
        vec_args += ["--tag", t]
    if getattr(args, "only", None):
        vec_args += ["--only", args.only]
    if getattr(args, "vault_frac", None) is not None:
        vec_args += ["--vault-frac", str(args.vault_frac)]
    if getattr(args, "model", None):
        vec_args += ["--model", args.model]
    rc, out = _vec_run(vec_args)
    if rc != 0:
        return rc
    emit_rows(json.loads(out), _SEM_COLS, args.json)
    return 0


def cmd_similar(args) -> int:
    rc, out = _vec_run(["similar", str(args.id), "--limit", str(args.limit),
                        "--min-score", str(args.min_score)])
    if rc != 0:
        return rc
    emit_rows(json.loads(out), _SEM_COLS, args.json)
    return 0


def cmd_dupes(args) -> int:
    vec_args = ["dupes", "--min-score", str(args.min_score),
                "--limit", str(args.limit)]
    if args.type:
        vec_args += ["--type", args.type]
    if getattr(args, "model", None):
        vec_args += ["--model", args.model]
    rc, out = _vec_run(vec_args)
    if rc != 0:
        return rc
    cols = ["id_a", "id_b", "type", "status_a", "status_b",
            "title_a", "title_b", "score"]
    emit_rows(json.loads(out), cols, args.json)
    return 0


# ---------------------------------------------------------------------------
# CLI parser
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mem",
        description="CLI wrapper su memories.db.",
        epilog=(
            "dates: absolute YYYY-MM-DD or relative (today, yesterday, tomorrow, +Nd, -Nd, +Nw, +Nm).\n"
            "When --date is omitted, writes use today with the early-morning rule:\n"
            "between 00:00 and 06:00 local the row is attributed to the previous day,\n"
            "so a session running past midnight stays on the lived day.\n"
            "Output: ASCII table on TTY, dense JSON on pipe; --json forces JSON.\n"
            "DB path: env MEM_DB overrides <repo-root>/private/memories.db.\n"
            "Exit code 3: strato semantico non disponibile (uv/Ollama mancanti) — fallback keyword.\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    # save
    sp = sub.add_parser("save", help="Save a memory")
    sp.add_argument("title", nargs="?", help="Memory title (omit with --bulk)")
    sp.add_argument("-d", "--description", help="Optional context: notes, links, reasoning")
    sp.add_argument("-t", "--tags", action="append", help="Tag (repeat or comma-separate)")
    sp.add_argument("--date", help="YYYY-MM-DD or relative (yesterday, -2d); omitted = today with early-morning rule")
    sp.add_argument("--bulk", action="store_true",
                    help='Read JSON array from stdin, insert all rows in one transaction. '
                         'Row keys: title (required), type, tags, description, date, due_date, priority, status')
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_save)

    # task
    sp = sub.add_parser("task", help="Create a task")
    sp.add_argument("title")
    sp.add_argument("-d", "--description", help="Optional context: notes, links, reasoning")
    sp.add_argument("-t", "--tags", action="append", help="Tag (repeat or comma-separate)")
    sp.add_argument("--due", help="Due date: YYYY-MM-DD or relative (tomorrow, +3d, +1w, +1m)")
    sp.add_argument("--priority", choices=["low", "normal", "high"])
    sp.add_argument("--date", help="YYYY-MM-DD or relative (yesterday, -2d); omitted = today with early-morning rule")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_task)

    # idea
    sp = sub.add_parser("idea", help="Open an idea")
    sp.add_argument("title")
    sp.add_argument("-d", "--description", help="Optional context: notes, links, reasoning")
    sp.add_argument("-t", "--tags", action="append", help="Tag (repeat or comma-separate)")
    sp.add_argument("--date", help="YYYY-MM-DD or relative (yesterday, -2d); omitted = today with early-morning rule")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_idea)

    # update
    sp = sub.add_parser("update", help="Patch an existing row")
    sp.add_argument("id", type=int)
    sp.add_argument("--title", help="New title")
    sp.add_argument("--description", help="New description (replaces the old one)")
    sp.add_argument("--tags", action="append", help="New tags (replace the old ones)")
    sp.add_argument("--status", help="task: todo|in_progress|done|cancelled; idea: open|done|dismissed")
    sp.add_argument("--due", help="Due date: YYYY-MM-DD or relative (tomorrow, +3d, +1w, +1m)")
    sp.add_argument("--priority", choices=["low", "normal", "high"])
    sp.add_argument("--date", help="YYYY-MM-DD or relative (yesterday, -2d); omitted = today with early-morning rule")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_update)

    # done
    sp = sub.add_parser("done", help="Mark task(s) as done")
    sp.add_argument("ids", type=int, nargs="+")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_done)

    # reopen
    sp = sub.add_parser("reopen", help="Reopen a task")
    sp.add_argument("id", type=int)
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_reopen)

    # marker
    sp = sub.add_parser("marker", help="Get/set a named marker")
    sp.add_argument("action", choices=["get", "set"], help="get prints the marker; set upserts it in place")
    sp.add_argument("name", help="Marker name, e.g. last-slacky-flush")
    sp.add_argument("value", nargs="?", help="New value (required with set)")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_marker)

    # today / todo / overdue
    for name, func, help_ in [
        ("today", cmd_today, "Rows dated today"),
        ("todo", cmd_todo, "Open tasks"),
        ("overdue", cmd_overdue, "Overdue open tasks"),
    ]:
        sp = sub.add_parser(name, help=help_)
        sp.add_argument("--json", action="store_true")
        sp.set_defaults(func=func)

    # search
    sp = sub.add_parser("search", help="Search rows")
    sp.add_argument("query", nargs="?", help="Free text, matched on title and description")
    sp.add_argument("--tag", action="append", help="Filter by tag (repeatable)")
    sp.add_argument("--type", choices=["memory", "task", "idea"])
    sp.add_argument("--status", help="task: todo|in_progress|done|cancelled; idea: open|done|dismissed")
    sp.add_argument("--since", help="Lower date bound (YYYY-MM-DD or relative)")
    sp.add_argument("--until", help="Upper date bound (YYYY-MM-DD or relative)")
    sp.add_argument("--limit", type=int, default=50, help="Max rows (default 50)")
    sp.add_argument("--semantic", action="store_true",
                    help="Ricerca per significato via embedding (richiede Ollama+uv)")
    sp.add_argument("--min-score", type=float, default=0.0, dest="min_score",
                    help="Score minimo con --semantic (0-1)")
    sp.add_argument("--model", help="Override modello embedding (solo con --semantic)")
    sp.add_argument("--only", choices=["memory", "vault"],
                    help="Restringe il recall a una sola sorgente")
    sp.add_argument("--vault-frac", type=float, default=0.6, dest="vault_frac",
                    help="Quota massima di risultati dal vault (anti-sommersione)")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_search)

    # show
    sp = sub.add_parser("show", help="Show a single row")
    sp.add_argument("id", type=int)
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_show)

    # stats
    sp = sub.add_parser("stats", help="Aggregate counts")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_stats)

    # embed (strato semantico)
    sp = sub.add_parser("embed", help="Vettorizza righe nuove/modificate (Ollama+uv)")
    sp.add_argument("--rebuild", action="store_true", help="Rigenera tutti gli embedding")
    sp.add_argument("--status", action="store_true", help="Report copertura, nessuna scrittura")
    sp.add_argument("--model", help="Override modello embedding")
    sp.add_argument("--root", action="append",
                    help="Radice del vault da indicizzare (ripetibile)")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_embed)

    # similar
    sp = sub.add_parser("similar", help="Righe semanticamente affini a un id")
    sp.add_argument("id", type=int)
    sp.add_argument("--limit", type=int, default=10)
    sp.add_argument("--min-score", type=float, default=0.0, dest="min_score")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_similar)

    # dupes
    sp = sub.add_parser("dupes", help="Coppie candidate duplicate (igiene)")
    sp.add_argument("--min-score", type=float, default=0.85, dest="min_score")
    sp.add_argument("--type", choices=["memory", "task", "idea"])
    sp.add_argument("--limit", type=int, default=50)
    sp.add_argument("--model", help="Override modello embedding")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(func=cmd_dupes)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except SystemExit:
        raise
    except Exception as e:
        sys.stderr.write(f"mem: error: {e}\n")
        return 1


if __name__ == "__main__":
    sys.exit(main())
