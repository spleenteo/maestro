#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["sqlite-vec>=0.1.6"]
# ///
# origin: maestro
# maestro_version: v2026.07.16.1
"""mem-vec — strato semantico di memories.db (data layer).

Usato da bin/mem (che fa da UX layer): questo script emette SEMPRE JSON
su stdout. Richiede uv (dipendenze PEP 723) e Ollama locale per gli
embedding. Exit code 3 = strato semantico non disponibile.
Path db: env MEM_DB > <repo>/private/memories.db.
"""
from __future__ import annotations

import argparse
import fnmatch
import hashlib
import json
import os
import re
import sqlite3
import struct
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

OLLAMA_URL = os.environ.get("MEM_OLLAMA_URL", "http://localhost:11434")
DEFAULT_MODEL = os.environ.get("MEM_EMBED_MODEL", "bge-m3")
EXIT_UNAVAILABLE = 3
BATCH_SIZE = 32

SCHEMA = """
CREATE TABLE IF NOT EXISTS log_vec (
  log_id INTEGER PRIMARY KEY REFERENCES log(id),
  model TEXT NOT NULL,
  dims INTEGER NOT NULL,
  content_hash TEXT NOT NULL,
  embedding BLOB NOT NULL,
  embedded_at TEXT NOT NULL
);
"""

SCHEMA_VAULT = """
CREATE TABLE IF NOT EXISTS vault_vec (
  chunk_id TEXT PRIMARY KEY,
  rel_path TEXT NOT NULL,
  heading TEXT,
  anchor TEXT,
  chunk_index INTEGER NOT NULL,
  model TEXT NOT NULL,
  dims INTEGER NOT NULL,
  content_hash TEXT NOT NULL,
  snippet TEXT NOT NULL,
  file_mtime REAL NOT NULL,
  embedding BLOB NOT NULL,
  embedded_at TEXT NOT NULL
);
CREATE INDEX IF NOT EXISTS vault_vec_relpath ON vault_vec(rel_path);
"""


def db_path() -> Path:
    env = os.environ.get("MEM_DB")
    if env:
        return Path(env).expanduser()
    return Path(__file__).resolve().parent.parent / "private" / "memories.db"


def connect() -> sqlite3.Connection:
    p = db_path()
    if not p.exists():
        sys.stderr.write(f"mem-vec: db not found at {p}\n")
        sys.exit(2)
    con = sqlite3.connect(str(p))
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA foreign_keys = ON")
    con.executescript(SCHEMA)
    con.executescript(SCHEMA_VAULT)
    return con


def load_vec(con: sqlite3.Connection) -> None:
    try:
        import sqlite_vec
    except ImportError:
        sys.stderr.write(
            "mem-vec: dipendenza sqlite-vec assente — esegui via "
            "'uv run --script bin/mem-vec'\n")
        sys.exit(EXIT_UNAVAILABLE)
    con.enable_load_extension(True)
    sqlite_vec.load(con)
    con.enable_load_extension(False)


def content_text(title: str | None, description: str | None, tags: str | None) -> str:
    return "\n".join(x for x in (title, description, tags) if x)


def content_hash(model: str, text: str) -> str:
    return hashlib.sha256(f"{model}\n{text}".encode("utf-8")).hexdigest()


def parse_frontmatter(text: str) -> tuple[dict, str]:
    """Estrae {description, tags} dal frontmatter YAML e ritorna (meta, body).
    Parsing minimale stdlib (nessuna dipendenza YAML); gestisce solo tags in
    flow form [a, b] — quella imposta dalla markdown discipline Maestro."""
    meta: dict = {}
    if not text.startswith("---"):
        return meta, text
    end = text.find("\n---", 3)
    if end == -1:
        return meta, text
    fm, body = text[3:end], text[end + 4:].lstrip("\n")
    for line in fm.splitlines():
        m = re.match(r"\s*(description|tags)\s*:\s*(.*)$", line)
        if not m:
            continue
        key, val = m.group(1), m.group(2).strip()
        if key == "tags":
            val = val.strip("[]")
            meta["tags"] = ", ".join(
                t.strip().strip("'\"") for t in val.split(",") if t.strip())
        else:
            meta["description"] = val.strip("'\"")
    return meta, body


def slugify(heading: str) -> str:
    s = re.sub(r"[^\w\s-]", "", heading.strip().lower())
    return re.sub(r"[\s_]+", "-", s).strip("-")


def split_sections(body: str) -> list[dict]:
    """Spezza il corpo sugli heading ## / ###. Il preambolo prima del primo
    heading (se non vuoto) è una sezione con heading=''. Gli heading dentro
    i fence di codice sono ignorati."""
    fence_re = re.compile(r"^\s*(```|~~~)")
    head_re = re.compile(r"^(#{2,3})\s+(.*)$")
    cur = {"heading": "", "heading_path": [], "level": 0, "lines": []}
    sections, stack, in_fence = [], [], False
    for line in body.splitlines():
        if fence_re.match(line):
            in_fence = not in_fence
            cur["lines"].append(line)
            continue
        m = None if in_fence else head_re.match(line)
        if m:
            if cur["lines"] or cur["heading"]:
                sections.append(cur)
            level, heading = len(m.group(1)), m.group(2).strip()
            stack = stack[:level - 2] + [heading]
            cur = {"heading": heading, "heading_path": list(stack),
                   "level": level, "lines": []}
        else:
            cur["lines"].append(line)
    if cur["lines"] or cur["heading"]:
        sections.append(cur)
    out = []
    for s in sections:
        text = "\n".join(s["lines"]).strip()
        if not text and not s["heading"]:
            continue
        out.append({"heading": s["heading"], "heading_path": s["heading_path"],
                    "level": s["level"], "text": text})
    return out


def count_words(text: str) -> int:
    return len(text.split())


def subsplit(text: str, max_words: int, overlap_words: int) -> list[str]:
    """Divide un testo lungo in sub-chunk di ~max_words parole con overlap.
    Ritorna [text] se già entro la soglia."""
    words = text.split()
    if len(words) <= max_words:
        return [text]
    step = max(1, max_words - overlap_words)
    parts, i = [], 0
    while i < len(words):
        parts.append(" ".join(words[i:i + max_words]))
        if i + max_words >= len(words):
            break
        i += step
    return parts


def build_embed_text(description: str, heading_path: list[str],
                     tags: str, chunk_text: str) -> str:
    """Cartello di contesto (description del file + catena heading + tags)
    anteposto al testo del chunk, per dare senso anche a heading criptici."""
    ctx = []
    if description:
        ctx.append(description)
    if heading_path:
        ctx.append(" › ".join(heading_path))
    if tags:
        ctx.append(tags)
    prefix = "\n".join(ctx)
    return f"{prefix}\n\n{chunk_text}" if prefix else chunk_text


def make_snippet(text: str, max_len: int = 160) -> str:
    flat = re.sub(r"\s+", " ", text).strip()
    return flat if len(flat) <= max_len else flat[:max_len - 1].rstrip() + "…"


def compute_chunk_id(rel_path: str, heading_path: list[str], sub_index: int) -> str:
    key = f"{rel_path}\x1f{' › '.join(heading_path)}\x1f{sub_index}"
    return hashlib.sha256(key.encode("utf-8")).hexdigest()


def chunk_file(path: Path, vault_root: Path,
               max_words: int = 1200, overlap_words: int = 100) -> list[dict]:
    rel_path = str(path.relative_to(vault_root))
    raw = path.read_text(encoding="utf-8", errors="replace")
    meta, body = parse_frontmatter(raw)
    description, tags = meta.get("description", ""), meta.get("tags", "")
    chunks = []
    for sec in split_sections(body):
        for sub_index, part in enumerate(subsplit(sec["text"], max_words, overlap_words)):
            chunks.append({
                "chunk_id": compute_chunk_id(rel_path, sec["heading_path"], sub_index),
                "rel_path": rel_path,
                "heading": sec["heading"],
                "anchor": slugify(sec["heading"]) if sec["heading"] else "",
                "chunk_index": sub_index,
                "embed_text": build_embed_text(
                    description, sec["heading_path"], tags, part),
                "snippet": make_snippet(part),
            })
    return chunks


def load_ignore(vault_root: Path):
    """Legge <vault_root>/.mem-ignore (stile .gitignore semplificato) e
    ritorna is_ignored(rel_path). Supporta: commenti (#), glob (fnmatch),
    dir con '/' finale, negazione '!'. Le dot-directory sono sempre ignorate."""
    patterns: list[tuple[bool, str]] = []
    ig = vault_root / ".mem-ignore"
    if ig.exists():
        for line in ig.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            neg = line.startswith("!")
            patterns.append((neg, (line[1:] if neg else line).rstrip("/")))

    def is_ignored(rel_path: str) -> bool:
        parts = rel_path.split("/")
        if any(p.startswith(".") for p in parts):
            return True
        ignored = False
        for neg, pat in patterns:
            hit = (fnmatch.fnmatch(rel_path, pat)
                   or fnmatch.fnmatch(rel_path, pat + "/*")
                   or any(fnmatch.fnmatch(seg, pat) for seg in parts))
            if hit:
                ignored = not neg
        return ignored

    return is_ignored


def walk_vault(roots: list[Path]):
    """Itera i .md sotto ciascuna radice, rispettando .mem-ignore.
    Yield (file_path, vault_root)."""
    for root in roots:
        root = Path(root).expanduser()
        if not root.is_dir():
            continue
        is_ignored = load_ignore(root)
        for path in sorted(root.rglob("*.md")):
            if not is_ignored(str(path.relative_to(root))):
                yield path, root


def vault_roots_from_env() -> list[Path]:
    raw = os.environ.get("MEM_VAULT_ROOTS", "")
    return [Path(p).expanduser() for p in raw.split(":") if p.strip()]


def pack(vec: list[float]) -> bytes:
    return struct.pack(f"<{len(vec)}f", *vec)


def unpack(blob: bytes) -> list[float]:
    n = len(blob) // 4
    return list(struct.unpack(f"<{n}f", blob))


def scan_state(con: sqlite3.Connection, model: str):
    """(pending, stale, ok) — item: {"id", "text", "hash"}."""
    logs = con.execute("SELECT id, title, description, tags FROM log").fetchall()
    vecs = {r["log_id"]: r for r in con.execute(
        "SELECT log_id, model, content_hash FROM log_vec").fetchall()}
    pending, stale, ok = [], [], []
    for l in logs:
        text = content_text(l["title"], l["description"], l["tags"])
        h = content_hash(model, text)
        item = {"id": l["id"], "text": text, "hash": h}
        v = vecs.get(l["id"])
        if v is None:
            pending.append(item)
        elif v["model"] != model or v["content_hash"] != h:
            stale.append(item)
        else:
            ok.append(item)
    return pending, stale, ok


def emit(obj) -> None:
    json.dump(obj, sys.stdout, ensure_ascii=False)
    sys.stdout.write("\n")


def ollama_embed(texts: list[str], model: str) -> list[list[float]]:
    req = urllib.request.Request(
        f"{OLLAMA_URL}/api/embed",
        data=json.dumps({"model": model, "input": texts}).encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            payload = json.loads(resp.read())
    except (urllib.error.URLError, OSError) as e:
        sys.stderr.write(
            f"mem-vec: Ollama non raggiungibile su {OLLAMA_URL} ({e}). "
            "Strato semantico non disponibile — usa la ricerca keyword.\n")
        sys.exit(EXIT_UNAVAILABLE)
    embs = payload.get("embeddings")
    if not embs or len(embs) != len(texts):
        sys.stderr.write(f"mem-vec: risposta inattesa da Ollama: {str(payload)[:200]}\n")
        sys.exit(1)
    return embs


def scan_vault_state(con, roots, model, *, max_words=1200, overlap=100,
                     use_mtime_skip=True):
    """(pending, stale, ok, orphans). item: dict del chunker + 'hash','mtime'.
    orphans: chunk_id spariti dal filesystem. Pre-filtro mtime: un file il
    cui mtime coincide con quello salvato per i suoi chunk non viene ri-letto."""
    existing = {r["chunk_id"]: r for r in con.execute(
        "SELECT chunk_id, rel_path, model, content_hash, file_mtime "
        "FROM vault_vec").fetchall()}
    by_rel: dict[str, list] = {}
    for r in existing.values():
        by_rel.setdefault(r["rel_path"], []).append(r)
    pending, stale, ok, seen = [], [], [], set()
    for path, root in walk_vault(roots):
        rel = str(path.relative_to(root))
        mtime = path.stat().st_mtime
        prior = by_rel.get(rel)
        if (use_mtime_skip and prior
                and all(p["model"] == model
                        and abs(p["file_mtime"] - mtime) < 1e-6 for p in prior)):
            for p in prior:
                seen.add(p["chunk_id"])
                ok.append({"chunk_id": p["chunk_id"], "_skip": True})
            continue
        for ch in chunk_file(path, root, max_words=max_words, overlap_words=overlap):
            cid = ch["chunk_id"]
            seen.add(cid)
            h = content_hash(model, ch["embed_text"])
            item = {**ch, "hash": h, "mtime": mtime}
            v = existing.get(cid)
            if v is None:
                pending.append(item)
            elif v["model"] != model or v["content_hash"] != h:
                stale.append(item)
            else:
                ok.append(item)
    orphans = [cid for cid in existing if cid not in seen]
    return pending, stale, ok, orphans


def _embed_vault(con, roots, model, now, rebuild) -> dict:
    pending, stale, ok, orphans = scan_vault_state(
        con, roots, model, use_mtime_skip=not rebuild)
    todo = pending + stale + (ok if rebuild else [])
    n = 0
    for i in range(0, len(todo), BATCH_SIZE):
        batch = todo[i:i + BATCH_SIZE]
        embs = ollama_embed([b["embed_text"] or "(vuoto)" for b in batch], model)
        with con:
            for item, embv in zip(batch, embs):
                con.execute(
                    "INSERT OR REPLACE INTO vault_vec (chunk_id, rel_path, heading,"
                    " anchor, chunk_index, model, dims, content_hash, snippet,"
                    " file_mtime, embedding, embedded_at) VALUES (?,?,?,?,?,?,?,?,?,?,?,?)",
                    (item["chunk_id"], item["rel_path"], item["heading"],
                     item["anchor"], item["chunk_index"], model, len(embv),
                     item["hash"], item["snippet"], item["mtime"], pack(embv), now))
        n += len(batch)
    if orphans:
        with con:
            con.executemany("DELETE FROM vault_vec WHERE chunk_id=?",
                            [(cid,) for cid in orphans])
    return {"embedded": n, "orphans_removed": len(orphans)}


def cmd_embed(args) -> int:
    model = args.model
    con = connect()
    t0 = time.monotonic()
    roots = ([Path(r).expanduser() for r in (args.root or [])]
             or vault_roots_from_env())
    pending, stale, ok = scan_state(con, model)
    if args.status:
        out = {"model": model, "memory": {
            "total": len(pending) + len(stale) + len(ok), "embedded": len(ok),
            "stale": len(stale), "missing": len(pending)}}
        if roots:
            vp, vs, vok, vorph = scan_vault_state(
                con, roots, model, use_mtime_skip=not args.rebuild)
            out["vault"] = {"total": len(vp) + len(vs) + len(vok),
                            "embedded": len(vok), "stale": len(vs),
                            "missing": len(vp), "orphans": len(vorph)}
        emit(out)
        return 0
    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    todo = pending + stale + (ok if args.rebuild else [])
    n = 0
    for i in range(0, len(todo), BATCH_SIZE):
        batch = todo[i:i + BATCH_SIZE]
        embs = ollama_embed([b["text"] or "(vuoto)" for b in batch], model)
        with con:
            for item, embv in zip(batch, embs):
                con.execute(
                    "INSERT OR REPLACE INTO log_vec "
                    "(log_id, model, dims, content_hash, embedding, embedded_at) "
                    "VALUES (?,?,?,?,?,?)",
                    (item["id"], model, len(embv), item["hash"], pack(embv), now))
        n += len(batch)
    result = {"embedded": n, "model": model,
              "seconds": round(time.monotonic() - t0, 2)}
    if roots:
        result["vault"] = _embed_vault(con, roots, model, now, args.rebuild)
    emit(result)
    return 0


def _score(r) -> float:
    return round(1 - r["distance"], 3)


def _scored(r) -> dict:
    d = {k: r[k] for k in ("id", "date", "type", "status", "title", "tags")}
    d["score"] = _score(r)
    return d


def _filters(args, params: list) -> list[str]:
    clauses = []
    if args.type:
        clauses.append("l.type=?"); params.append(args.type)
    if args.status:
        clauses.append("l.status=?"); params.append(args.status)
    if args.since:
        clauses.append("l.date>=?"); params.append(args.since)
    if args.until:
        clauses.append("l.date<=?"); params.append(args.until)
    for t in (args.tag or []):
        clauses.append("l.tags LIKE ?"); params.append(f"%{t}%")
    return clauses


_SELECT_SCORED = (
    "SELECT l.id, l.date, l.type, l.status, l.title, l.tags, "
    "vec_distance_cosine(v.embedding, ?) AS distance "
    "FROM log l JOIN log_vec v ON v.log_id = l.id ")


def cmd_search(args) -> int:
    con = connect()
    load_vec(con)
    qvec = pack(ollama_embed([args.query], args.model)[0])
    params: list = [qvec, args.model]
    clauses = _filters(args, params)
    where = (" AND " + " AND ".join(clauses)) if clauses else ""
    rows = con.execute(
        _SELECT_SCORED + f"WHERE v.model = ?{where} ORDER BY distance ASC LIMIT ?",
        (*params, args.limit)).fetchall()
    emit([_scored(r) for r in rows if _score(r) >= args.min_score])
    return 0


def cmd_similar(args) -> int:
    con = connect()
    load_vec(con)
    row = con.execute(
        "SELECT embedding, model FROM log_vec WHERE log_id=?", (args.id,)).fetchone()
    if row is None:
        sys.stderr.write(
            f"mem-vec: nessun embedding per #{args.id} — esegui prima 'mem embed'\n")
        return 1
    rows = con.execute(
        _SELECT_SCORED + "WHERE v.model = ? AND l.id != ? ORDER BY distance ASC LIMIT ?",
        (row["embedding"], row["model"], args.id, args.limit)).fetchall()
    emit([_scored(r) for r in rows if _score(r) >= args.min_score])
    return 0


def cmd_dupes(args) -> int:
    con = connect()
    load_vec(con)
    max_distance = 1 - args.min_score
    type_clause = " AND la.type = ?" if args.type else ""
    params: list = [args.model, args.model]
    if args.type:
        params.append(args.type)
    params += [max_distance, args.limit]
    rows = con.execute(
        "SELECT * FROM ("
        "  SELECT a.log_id AS id_a, b.log_id AS id_b, la.type AS type, "
        "         la.title AS title_a, lb.title AS title_b, "
        "         la.status AS status_a, lb.status AS status_b, "
        "         vec_distance_cosine(a.embedding, b.embedding) AS distance "
        "  FROM log_vec a JOIN log_vec b ON a.log_id < b.log_id "
        "  JOIN log la ON la.id = a.log_id JOIN log lb ON lb.id = b.log_id "
        f" WHERE a.model = ? AND b.model = ? AND la.type = lb.type{type_clause}"
        ") WHERE distance <= ? ORDER BY distance ASC LIMIT ?",
        params).fetchall()
    emit([{**{k: r[k] for k in ("id_a", "id_b", "type", "title_a", "title_b",
                                "status_a", "status_b")}, "score": _score(r)}
          for r in rows])
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mem-vec",
        description="Strato semantico di memories.db (emette JSON; usato da bin/mem).")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("embed", help="Vettorizza righe nuove/modificate")
    sp.add_argument("--rebuild", action="store_true", help="Rigenera tutto da zero")
    sp.add_argument("--status", action="store_true", help="Solo report copertura")
    sp.add_argument("--model", default=DEFAULT_MODEL)
    sp.add_argument("--root", action="append",
                    help="Radice del vault da indicizzare (ripetibile)")
    sp.set_defaults(func=cmd_embed)

    sp = sub.add_parser("search", help="Ricerca semantica")
    sp.add_argument("query")
    sp.add_argument("--type")
    sp.add_argument("--status")
    sp.add_argument("--since")
    sp.add_argument("--until")
    sp.add_argument("--tag", action="append")
    sp.add_argument("--limit", type=int, default=20)
    sp.add_argument("--min-score", type=float, default=0.0, dest="min_score")
    sp.add_argument("--model", default=DEFAULT_MODEL)
    sp.set_defaults(func=cmd_search)

    sp = sub.add_parser("similar", help="Righe affini a un id dato")
    sp.add_argument("id", type=int)
    sp.add_argument("--limit", type=int, default=10)
    sp.add_argument("--min-score", type=float, default=0.0, dest="min_score")
    sp.set_defaults(func=cmd_similar)

    sp = sub.add_parser("dupes", help="Coppie candidate duplicate")
    sp.add_argument("--min-score", type=float, default=0.85, dest="min_score")
    sp.add_argument("--type")
    sp.add_argument("--limit", type=int, default=50)
    sp.add_argument("--model", default=DEFAULT_MODEL)
    sp.set_defaults(func=cmd_dupes)

    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
